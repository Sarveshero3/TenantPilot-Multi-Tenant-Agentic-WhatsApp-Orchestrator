# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/tenantpilot?retryWrites=true&w=majority
MONGODB_DB_NAME=tenantpilot

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
# Set WHATSAPP_MODE=mock to log payloads without a real Meta account
# Set WHATSAPP_MODE=real to send live messages via Meta Graph API
WHATSAPP_MODE=mock
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_VERIFY_TOKEN=tenantpilot_verify_secret_change_me

# ── LLM — NVIDIA AI Endpoints (free tier) ────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO
